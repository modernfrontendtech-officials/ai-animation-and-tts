# Shared infrastructure
POSTGRES_DSN=postgresql+psycopg://video_user:video_pass@postgres:5432/video_factory
REDIS_URL=redis://redis:6379/0

# MinIO / S3 storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=video-assets
MINIO_SECURE=false

# Backend runtime
APP_NAME=AI Video Factory
DEBUG=true
ARTIFACT_ROOT=/tmp/video-factory
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
DEFAULT_RUNTIME_MINUTES=25
MIN_SCENE_SECONDS=10
MAX_SCENE_SECONDS=15
SOCKET_NAMESPACE=/ws
SOCKET_CHANNEL=video_factory_socketio
ENABLE_DEMO_ASSETS=true
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Frontend runtime
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SOCKET_URL=http://localhost:8000
NEXT_PUBLIC_SOCKET_NAMESPACE=/ws

# Reverse proxy
SITE_HOST=localhost
